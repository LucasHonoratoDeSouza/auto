# App
APP_ENV=development
WORKSPACE_ROOT=workspace
OUTPUT_ROOT=output
TMP_ROOT=.tmp
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe

# YouTube / ingestao
YT_DLP_COOKIES_FILE=
YOUTUBE_PROXY_URL=

# Transcricao - gratis por padrao
TRANSCRIPTION_PROVIDER=auto
LOCAL_TRANSCRIPTION_MODEL=small
LOCAL_TRANSCRIPTION_DEVICE=cpu
LOCAL_TRANSCRIPTION_COMPUTE_TYPE=int8
LOCAL_TRANSCRIPTION_BEAM_SIZE=5
LOCAL_TRANSCRIPTION_VAD_FILTER=true

# OpenAI - fallback opcional
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
OPENAI_TRANSCRIPTION_LANGUAGE=pt
OPENAI_REQUEST_TIMEOUT_SECONDS=180
TRANSCRIPTION_MAX_AUDIO_BYTES=18000000
TRANSCRIPTION_CHUNK_MINUTES=15

# Groq - opcional para LLM gratis / barato
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.1-8b-instant
GROQ_REQUEST_TIMEOUT_SECONDS=60

# TikTok Login Kit + Content Posting API
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8080/auth/tiktok/callback
TIKTOK_SCOPES=user.info.basic,video.publish,video.upload
TIKTOK_USER_ACCESS_TOKEN=
TIKTOK_USER_REFRESH_TOKEN=
TIKTOK_OPEN_ID=
TIKTOK_WEBHOOK_URL=
TIKTOK_WEBHOOK_VERIFY_TOKEN=
TIKTOK_UPLOAD_CHUNK_SIZE_MB=10

# Entrega da fila
QUEUE_EXECUTION_MODE=notify_email
NOTIFICATION_LEAD_MINUTES=5
APP_PUBLIC_BASE_URL=
NOTIFICATION_EMAIL_TO=
NOTIFICATION_EMAIL_FROM=
NOTIFICATION_EMAIL_SENDER_NAME=
NOTIFICATION_ATTACH_VIDEO_MAX_MB=20
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# Defaults de postagem
POST_DEFAULT_PRIVACY_LEVEL=SELF_ONLY
POST_ALLOW_COMMENT=true
POST_ALLOW_DUET=true
POST_ALLOW_STITCH=true
POST_IS_AIGC=false

# Compliance / operacao
SOURCE_RIGHTS_POLICY=strict
STORAGE_PUBLIC_BASE_URL=
STORAGE_UPLOAD_ROOT=

# Meta de growth / aprendizado
GOAL_FOLLOWERS=10000
GOAL_TOTAL_VIEWS=100000
REWARD_TARGET_VIEWS_PER_POST=5000
REWARD_TARGET_FOLLOWS_PER_POST=25
REWARD_TARGET_SHARES_PER_POST=20
REWARD_TARGET_PROFILE_VISITS_PER_POST=50
REWARD_TARGET_COMPLETION_RATE=0.35
BANDIT_EXPLORATION_FLOOR=0.25
PIVOT_POST_WINDOW=12
PIVOT_MIN_EXPECTED_REWARD=0.35
